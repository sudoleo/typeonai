FIREBASE_API_KEY=XXXX
FIREBASE_AUTH_DOMAIN=dein-projekt.firebaseapp.com
FIREBASE_PROJECT_ID=dein-projekt
FIREBASE_STORAGE_BUCKET=dein-projekt.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456

DEVELOPER_OPENAI_API_KEY=sk
DEVELOPER_MISTRAL_API_KEY=sk
DEVELOPER_ANTHROPIC_API_KEY=sk
DEVELOPER_GEMINI_API_KEY=sk
DEVELOPER_DEEPSEEK_API_KEY=sk

# Optional, admin-triggered read-only SEO content judge. It reuses the server
# OpenAI key above and remains disabled unless a model is explicitly set.
SEO_CONTENT_JUDGE_MODEL=

# Optional single-call weekly SEO portfolio judge. Falls back to the content
# judge model above when left empty; both use the same server OpenAI key.
SEO_PORTFOLIO_JUDGE_MODEL=

# Consensus Watch e-mail delivery and signed one-click unsubscribe links.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
WATCH_UNSUBSCRIBE_SECRET=

# Google Search Console (read-only Search Analytics). Despite the variable
# name, this value is always a service-account JSON file path. Relative paths
# resolve from the repository root; Render may use /etc/secrets/....
GSC_SITE_URL=sc-domain:consens.io
GSC_SERVICE_ACCOUNT_JSON=gen-lang-client-0234219247-e1d621f936a2.json

# One shared deadline for blocking Firestore maintenance during app startup.
# The server continues with in-code defaults/background recovery after timeout.
STARTUP_JOB_TIMEOUT_SECONDS=15
